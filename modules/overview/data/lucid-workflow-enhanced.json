          "field_label": "Registrations Confirmed",
          "data_type": "integer",
          "required": false,
          "description": "Number of confirmed registrations",
          "validation_field": "Minimum_registrations",
          "validation_description": "Must meet or exceed minimum registration threshold"
        },
        "Sent_to_Spec_for_Enrolment_Link": {
          "field_name": "Event_URL",
          "field_label": "Course URL",
          "data_type": "website",
          "required": false,
          "description": "Public URL for course enrolment",
          "related_workflow": "Sync Course to Wordpress"
        }
      },
      "related_workflows": [
        {
          "workflow_id": "52330000003463406",
          "workflow_name": "Check Min registration",
          "trigger_type": "date_or_datetime",
          "active": true,
          "description": "Validates minimum registration levels are met",
          "condition_fields": [],
          "workflow_url": "https://crm.zoho.com.au/crm/org7003757385/settings/workflow-rules/52330000003463406"
        },
        {
          "workflow_id": "52330000002460212",
          "workflow_name": "Sync Course to Wordpress",
          "trigger_type": "create",
          "active": false,
          "description": "Publishes course to public website",
          "workflow_url": "https://crm.zoho.com.au/crm/org7003757385/settings/workflow-rules/52330000002460212"
        },
        {
          "workflow_id": "52330000006315389",
          "workflow_name": "Sync Course to Wordpress",
          "trigger_type": "field_update",
          "active": true,
          "description": "Updates website when course status changes",
          "condition_fields": [
            "Course_Status"
          ],
          "workflow_url": "https://crm.zoho.com.au/crm/org7003757385/settings/workflow-rules/52330000006315389"
        },
        {
          "workflow_id": "52330000011998036",
          "workflow_name": "Course Confirmed - Website Calendar",
          "trigger_type": "field_update",
          "active": true,
          "description": "Publishes to website calendar when confirmed",
          "condition_fields": [
            "Course_Confirmed"
          ],
          "workflow_url": "https://crm.zoho.com.au/crm/org7003757385/settings/workflow-rules/52330000011998036"
        }
      ],
      "key_fields": [
        "Minimum_registrations",
        "Registrations_Confirmed",
        "Registrations_Booked",
        "Course_Status",
        "Course_Confirmed",
        "Published_on",
        "Published_Date"
      ],
      "next_stage_trigger": {
        "field": "Course_Status",
        "condition": "Minimum registrations met and course approved",
        "description": "Advances when approval criteria satisfied"
      },
      "next": "Coursework"
    },
