      "stage_order": 1,
      "description": "Initial course creation and setup phase",
      "zoho_module": "Courses",
      "outputs": {
        "Course_Date": {
          "field_name": "Course_Start_Time",
          "field_label": "Course Start Time",
          "data_type": "datetime",
          "required": false,
          "description": "Start date and time for the course"
        },
        "Course_Location": {
          "field_name": "Venue_Location",
          "field_label": "Venue Location",
          "data_type": "text",
          "required": false,
          "description": "Physical location where course will be held",
          "related_field": "Select_Venue",
          "related_field_type": "lookup",
          "lookup_module": "Venues"
        },
        "Course_Trainer": {
          "field_name": "Course_Trainer",
          "field_label": "Course Trainer",
          "data_type": "lookup",
          "lookup_module": "Contacts",
          "required": false,
          "description": "Assigned trainer for the course"
        },
        "Course_Details": {
          "field_name": "Course_Description",
          "field_label": "Course Description",
          "data_type": "textarea",
          "required": false,
          "description": "Detailed description of the course content"
        }
      },
      "mandatory_fields": [
        {
          "field_name": "Name",
          "field_label": "Course Name",
          "data_type": "text",
          "system_mandatory": true
        }
      ],
      "related_workflows": [
        {
          "workflow_id": "52330000002444506",
          "workflow_name": "Udpate Course ID",
          "trigger_type": "create",
          "active": true,
          "description": "Automatically assigns unique course identifier",
          "workflow_url": "https://crm.zoho.com.au/crm/org7003757385/settings/workflow-rules/52330000002444506"
        },
        {
          "workflow_id": "52330000002661635",
          "workflow_name": "Create Tasks for Course",
          "trigger_type": "create",
          "active": true,
          "description": "Generates team tasks for course preparation",
          "workflow_url": "https://crm.zoho.com.au/crm/org7003757385/settings/workflow-rules/52330000002661635"
        },
        {
          "workflow_id": "52330000004013116",
          "workflow_name": "Naming Convention - Course",
          "trigger_type": "create_or_edit",
          "active": true,
          "description": "Ensures course follows naming standards",
          "workflow_url": "https://crm.zoho.com.au/crm/org7003757385/settings/workflow-rules/52330000004013116"
        },
        {
          "workflow_id": "52330000002462001",
          "workflow_name": "Courses_ZohoFlow_CRM Course to Workdrive Folder",
          "trigger_type": "create",
          "active": true,
          "description": "Creates folder structure in Workdrive",
          "workflow_url": "https://crm.zoho.com.au/crm/org7003757385/settings/workflow-rules/52330000002462001"
        },
        {
          "workflow_id": "52330000008928362",
          "workflow_name": "Course Performance Record",
          "trigger_type": "create",
          "active": true,
          "description": "Initialises performance tracking record",
          "workflow_url": "https://crm.zoho.com.au/crm/org7003757385/settings/workflow-rules/52330000008928362"
        }
      ],
      "key_fields": [
        "Course_Type",
        "Course_Code",
        "Course_Qualification",
        "Maximum_registrations",
        "Minimum_registrations",
        "Fees",
        "Course_End_Time"
