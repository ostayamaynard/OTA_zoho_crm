{
  "workflow_metadata": {
    "name": "Course Operations Workflow",
    "description": "Complete lifecycle workflow for course management from creation to archiving",
    "primary_module": "Courses",
    "created_date": "2025-11-13",
    "data_source": "Zoho CRM Data Model 2025-11-13"
  },
  "operations_flow": {
