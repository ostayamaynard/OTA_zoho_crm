        {
          "workflow_id": "52330000006093561",
          "workflow_name": "Send Course email",
          "trigger_type": "field_update",
          "trigger": "manual",
          "condition_field": "Course_Email",
          "description": "Sends course details email",
          "workflow_url": "https://crm.zoho.com.au/crm/org7003757385/settings/workflow-rules/52330000006093561"
        }
