{
  "workflow_metadata": {
    "name": "Leads Customer Journey",
    "description": "Lead lifecycle from entry through qualification to conversion",
    "primary_module": "Leads",
    "created_date": "2025-11-13",
    "data_source": "Zoho CRM Data Model 2025-11-13"
  },
  "customer_journey": {
    "Lead_Entry": {
      "stage_order": 1,
      "description": "Lead enters system through various channels",
      "entry_points": {
        "website_form": {
          "source": "WordPress website",
          "trigger": "third_party",
          "creates": "Lead record",
          "fields_populated": [
            "First_Name",
            "Last_Name",
            "Email",
            "Mobile",
            "Course (lookup)",
            "Course_Type",
            "Payment_source"
          ]
        },
        "google_ads": {
          "source": "Google Ads conversion",
          "trigger": "third_party",
          "fields_populated": [
            "GCLID",
            "Ad_Campaign_Name",
            "Keyword",
            "ZCAMPAIGNID",
            "ADGROUPID"
          ]
        },
        "facebook_ads": {
          "source": "Facebook lead form",
          "trigger": "third_party",
          "fields_populated": [
            "leadchain0__Social_Lead_ID"
          ]
        },
        "manual_entry": {
          "source": "CRM user",
          "trigger": "human_input",
          "required_fields": [
            "Last_Name"
          ]
        }
      },
      "next": "Lead_Created"
    },
