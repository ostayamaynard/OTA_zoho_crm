      "related_workflows": [
        {
          "workflow_id": "52330000008228472",
          "workflow_name": "Generate Payment URL",
          "trigger_type": "field_update",
          "trigger": "manual",
          "condition_field": "WF_Action",
          "condition_value": "Generate Payment URL",
          "description": "Generates Zoho Form payment link",
          "workflow_url": "https://crm.zoho.com.au/crm/org7003757385/settings/workflow-rules/52330000008228472"
        },
        {
