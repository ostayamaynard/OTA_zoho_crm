  "workflow_decision_tree": {
    "when_lead_created": [
      {
        "step": 1,
        "event": "Lead record created",
        "triggers": "5 automatic workflows fire immediately",
        "workflows": [
          "New Lead Notification",
          "CallWithIn24Hours and Team Task",
          "Format Number",
          "Lead Owner Assignment",
          "Tag G-Series Leadership Leads"
        ],
        "color": "green",
        "type": "automatic"
      }
    ],
    "when_course_selected": [
      {
        "step": 1,
        "event": "User selects Course lookup field",
        "triggers": "1 automatic workflow fires",
        "workflows": [
          "Course Details Udpated"
        ],
        "action": "Lead updated with course details",
        "color": "green",
        "type": "automatic"
      }
    ],
    "when_wf_action_set_to_generate_payment_url": [
      {
        "step": 1,
        "event": "User sets WF_Action = 'Generate Payment URL'",
        "triggers": "1-2 manual workflows fire",
        "workflows": [
          "Generate Payment URL",
          "Update Location URL"
        ],
        "action": "Payment URL generated, lead proceeds to conversion",
        "color": "blue",
        "type": "manual"
      }
    ],
    "when_payment_received": [
      {
        "step": 1,
        "event": "Stripe payment webhook received",
        "triggers": "1 automatic workflow fires",
        "workflows": [
          "Convert on Payment Success"
        ],
        "action": "Lead converted to Contact, Account, Deal, Registration, Invoice",
        "color": "green",
        "type": "automatic",
        "important": true
      }
    ],
    "when_wf_action_set_to_convert": [
      {
        "step": 1,
        "event": "User sets WF_Action to conversion option",
        "triggers": "1 manual workflow fires",
        "workflows": [
          "Convert Pay Via Invoice",
          "Convert Non Paying Lead",
          "Convert to Only Create a contact"
        ],
        "action": "Lead converted based on WF_Action value",
        "color": "blue",
        "type": "manual"
      }
    ]
  },
